model User {
    id        String    @id @default(uuid(7))
    name      String
    email     String    @unique
    password  String
    phone     String?
    
    role      UserRole  @default(CUSTOMER)
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    orders    Order[]
    
    @@index([email])
    @@map("users")
}